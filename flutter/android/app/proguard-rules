# Keep class members from protobuf generated code.
-keepclassmembers class * extends com.google.protobuf.GeneratedMessageLite {
  <fields>;
}
# Remove Kotlin null-checks at runtime (⚠️ unsafe, may cause plain NPE)
-assumenosideeffects class kotlin.jvm.internal.Intrinsics {
    public static void checkNotNullExpressionValue(java.lang.Object, java.lang.String);
    public static void checkNotNullParameter(java.lang.Object, java.lang.String);
    public static void checkNotNull(java.lang.Object);
}

# Keep the isolated CloudSend ADB module stable for future MethodChannel/JNI entry points.
-keep class com.cloudsend.app.adb.** { *; }

# Keep ZEGO public SDK classes stable when Android release minification is enabled.
-keep class **.zego.** { *; }
-keep class im.zego.** { *; }
-keep class com.zego.** { *; }
-keep class plugins.zego.** { *; }
